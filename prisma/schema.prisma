datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String
  name             String?
  facebookPageName String    @default("Mayor's Page")
  sessions         Session[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model SystemLog {
  id        String   @id @default(uuid())
  action    String
  details   String
  createdAt DateTime @default(now())
}

model FacebookGroup {
  id           String      @id @default(uuid())
  name         String
  url          String      @unique
  membersCount Int         @default(0)
  dailyPosts   Int         @default(0)
  allowsPages  Boolean     @default(false)
  status       String      @default("NOT_JOINED") // NOT_JOINED, JOIN_PENDING, JOINED, BLACKLISTED
  notes        String?
  posts        GroupPost[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model GroupPost {
  id             String        @id @default(uuid())
  groupId        String
  group          FacebookGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  content        String
  imagePath      String?
  status         String        @default("PENDING") // PENDING, PROCESSING, PUBLISHED, FAILED, MODERATION_PENDING
  errorDetails   String?
  screenshotPath String?       // Web-accessible path like /screenshots/xxxx.png
  likesCount     Int           @default(0)
  commentsCount  Int           @default(0)
  postedAs       String        @default("Mayor's Page")
  scheduledAt    DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model FacebookSession {
  id        String   @id @default(uuid())
  profileId String   @unique
  stateJson String   // Stores the stringified Playwright storageState JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

